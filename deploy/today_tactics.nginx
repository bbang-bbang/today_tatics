# Rate limit zone — IP당 분당 60 요청 (P7 권고, DoS 완화)
limit_req_zone $binary_remote_addr zone=tt_general:10m rate=60r/m;
# trigger-update는 더 엄격 — IP당 분당 1회 (burst 2)
limit_req_zone $binary_remote_addr zone=tt_trigger:1m rate=1r/m;

# ── HTTP (80) → HTTPS (443) redirect + IP 직접 접근도 HTTPS로 강제 ─
server {
    listen 80 default_server;
    server_name today-tactics.co.kr www.today-tactics.co.kr _;
    server_tokens off;
    # certbot challenge 경로는 평문 유지 (cert 갱신 시 필요)
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }
    location / {
        return 301 https://today-tactics.co.kr$request_uri;
    }
}

# ── HTTPS (443) ─────────────────────────────────────────────
server {
    listen 443 ssl default_server;
    server_name today-tactics.co.kr www.today-tactics.co.kr _;

    # cert (이미 certbot으로 발급됨 — today-tactics.co.kr + www)
    ssl_certificate     /etc/letsencrypt/live/today-tactics.co.kr/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/today-tactics.co.kr/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # ── 보안 헤더 (P7 권고) ─────────────────────────────────
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # 서버 정보 노출 최소화
    server_tokens off;

    # 요청 본문 크기 제한 (saves/squads JSON, DoS 완화)
    client_max_body_size 1m;

    # 정적 파일은 Nginx가 직접 서빙 (Flask 우회 → 빠름)
    location /static/ {
        alias /opt/today_tactics/static/;
        expires 1h;
        add_header Cache-Control "public";
        add_header X-Content-Type-Options "nosniff" always;
    }

    # 트리거 엔드포인트 — 강한 rate limit
    location = /api/trigger-update {
        limit_req zone=tt_trigger burst=2 nodelay;
        proxy_pass         http://127.0.0.1:5000;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    # 나머지는 Gunicorn(Flask)으로 프록시
    location / {
        limit_req zone=tt_general burst=20 nodelay;
        proxy_pass         http://127.0.0.1:5000;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }
}
